@_require_auth
async def api_update_text(request: web.Request) -> web.Response:
    try:
        data    = await request.json()
        name    = data.get("name")
        content = (data.get("content") or "").strip()
        async with ddb() as db:
            if content:
                await db.execute(
                    "INSERT OR REPLACE INTO texts (name, content, updated_at) VALUES (?, ?, ?)",
                    (name, content, _now_str()),
                )
            else:
                await db.execute("DELETE FROM texts WHERE name=?", (name,))
            await db.commit()
        return web.json_response({"status": "ok"})
    except Exception as exc:
        return web.json_response({"error": str(exc)}, status=500)


