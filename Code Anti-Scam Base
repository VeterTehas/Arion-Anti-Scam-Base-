_fsm_timers: Dict[int, asyncio.TimerHandle] = {}


def fsm_schedule(user_id: int, state: FSMContext) -> None:
    if user_id in _fsm_timers:
        _fsm_timers[user_id].cancel()

    async def _clear() -> None:
        if await state.get_state():
            await state.clear()

    loop = asyncio.get_running_loop()
    _fsm_timers[user_id] = loop.call_later(
        FSM_TIMEOUT_SEC,
        lambda: asyncio.create_task(_clear()),
    )


def fsm_cancel(user_id: int) -> None:
    handle = _fsm_timers.pop(user_id, None)
    if handle:
        handle.cancel()

