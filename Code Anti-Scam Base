def _now_str() -> str:
    """Human-readable datetime used in display fields."""
    return datetime.now().strftime("%d.%m.%Y %H:%M")


def _now_iso() -> str:
    """ISO-format datetime used in DB comparison fields (warnings, bans)."""
    return datetime.now().strftime("%Y-%m-%d %H:%M")


def sanitize(text: Any) -> str:
    if not text:
        return ""
    return str(text).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")


def validate_identifier(identifier: str) -> Optional[str]:
    ident = identifier.strip().lstrip("@")
    if re.match(r"^[a-zA-Z0-9_]{4,32}$|^\d{5,15}$", ident):
        return ident
    return None


def progress_bar(pct: int) -> str:
    filled = int(10 * pct / 100)
    return f"[{'█' * filled}{'░' * (10 - filled)}] {pct}%"


def parse_time_delta(text: str) -> Optional[timedelta]:
    """Парсит строку '5 days' / '15 hours' / '30 minutes' → timedelta."""
    if not text:
        return None
    m = re.match(r"(\d+)\s*(day|days|d|hour|hours|h|minute|minutes|min|m)", text.lower())
    if not m:
        return None
    value, unit = int(m.group(1)), m.group(2)
    if unit.startswith("d"):
        return timedelta(days=value)
    if unit.startswith("h"):
        return timedelta(hours=value)
    return timedelta(minutes=value)

