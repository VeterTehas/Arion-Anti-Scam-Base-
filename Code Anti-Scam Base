async def _resolve_target(message: Message, target_text: str):
    """
    Разрешает цель команды модерации.
    Принимает числовой ID или @username из reply.
    Возвращает (user_id, display_name) или (None, None).
    """
    target_text = target_text.lstrip("@")

    # Числовой ID — используем напрямую
    if target_text.isdigit():
        uid = int(target_text)
        try:
            member = await message.chat.get_member(uid)
            return uid, member.user.first_name or str(uid)
        except Exception:
            return uid, str(uid)

    # @username — проверяем reply или запрашиваем через API
    if message.reply_to_message:
        user = message.reply_to_message.from_user
        if user.username and user.username.lower() == target_text.lower():
            return user.id, user.first_name or user.username

    # Попытка получить через get_chat (работает только если user писал боту)
    try:
        chat = await message.bot.get_chat(f"@{target_text}")
        return chat.id, chat.first_name or target_text
    except Exception:
        pass

    return None, None


@router.message(Command("mute"), IsStaffFilter())
async def cmd_mute(message: Message) -> None:
    if message.chat.type == "private":
        await message.answer("❌ Команда работает только в группах!")
        return

    args = message.text.split(maxsplit=2)
    if len(args) < 2:
        await message.answer(
            "❌ Формат: `/mute @username|ID [время]`\n"
            "Примеры: `/mute 123456 5 days`, `/mute @user 15 hours`",
            parse_mode="Markdown",
        )
        return

    uid, display_name = await _resolve_target(message, args[1])
    if uid is None:
        await message.answer(
            f"❌ Пользователь `{args[1]}` не найден. "
            f"Используйте числовой ID или ответьте на сообщение.",
            parse_mode="Markdown",
        )
        return

    duration: timedelta
    if len(args) >= 3:
        delta = parse_time_delta(args[2])
        if not delta:
