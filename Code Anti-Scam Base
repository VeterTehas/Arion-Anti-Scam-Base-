@router.message(Command("check_list"))
async def cmd_check_list(message: Message) -> None:
    """Массовая проверка: /check_list user1, user2, user3"""
    if not await subscription_gate(message):
        return
    if not await rate_ok(message.from_user.id):
        await message.answer(f"⚡ Подождите {RATE_LIMIT_SECONDS} сек.")
        return
    parts = message.text.split(maxsplit=1)
    if len(parts) < 2:
        await message.answer(
            "❓ Формат: `/check_list user1, user2, user3`",
            parse_mode="Markdown",
        )
        return
    raw_list = [x.strip().lstrip("@") for x in parts[1].replace(",", " ").split() if x.strip()]
    identifiers = [validate_identifier(x) for x in raw_list]
    identifiers = [x for x in identifiers if x]
    if not identifiers:
        await message.answer("❌ Не найдено корректных идентификаторов!")
        return
    if len(identifiers) > 10:
        await message.answer("⚠️ Максимум 10 за раз!")
        identifiers = identifiers[:10]

    status_msg = await message.answer(
        f"{HEADER}\n{DIVIDER}\n\n🔎 *МАССОВАЯ ПРОВЕРКА*\n\n⏳ Проверяю {len(identifiers)} записей...\n\n{FOOTER}",
        parse_mode="Markdown",
    )

    lines: List[str] = []
    for ident in identifiers:
        await inc_stat("checks")
        staff_role: Optional[str] = None
        if ident.isdigit():
            staff_role = await get_role(int(ident))
        user_row = await db_get_user(ident)

        if staff_role:
            role_label = ROLE_LABELS.get(staff_role, staff_role)
            lines.append(f"🛡️ `{ident}` — *{role_label}* (сотрудник)")
            await db_add_history(str(message.from_user.id), ident, "clean")
        elif user_row:
            await inc_stat("found")
            st    = user_row["status"]
            emoji = STATUS_EMOJI.get(st, "🔥")
            lines.append(f"{emoji} `{ident}` — *{st.upper()}* | {sanitize(user_row['reason'])[:60]}")
            await db_add_history(str(message.from_user.id), ident, "found")
        else:
            await inc_stat("clean")
            lines.append(f"🫧 `{ident}` — *ЧИСТ*")
            await db_add_history(str(message.from_user.id), ident, "clean")

    result = f"{HEADER}\n{DIVIDER}\n\n🔎 *Результат проверки ({len(identifiers)})*\n\n"
    result += "\n".join(lines)
    result += (
        f"\n\n{LINE}\n"
        f"📋 *Примечание:*\n"
        f"Отсутствие в базе не гарантирует безопасность. "
        f"Проводите сделки через официальных гарантов ARION и проверяйте пользователей в других базах.\n"
        f"{LINE}\n\n"
        f"{DIVIDER}\n{FOOTER}"
    )
    try:
        await status_msg.edit_text(result, parse_mode="Markdown")
    except Exception:
        await message.answer(result, parse_mode="Markdown")
    log.info("check_list %s by %d", identifiers, message.from_user.id)


