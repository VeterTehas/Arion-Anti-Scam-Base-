# Mapping of known where-clause presets to safe parameterised forms
_WHERE_PRESETS: Dict[str, Tuple[str, Tuple]] = {
    "active=1":                        ("active=?",          (1,)),
    "status='pending'":                ("status=?",          ("pending",)),
    "status='pending_review'":         ("status=?",          ("pending_review",)),
    "status='reviewer_approved'":      ("status=?",          ("reviewer_approved",)),
    "status='scammer'":                ("status=?",          ("scammer",)),
    "status='guarantor'":              ("status=?",          ("guarantor",)),
    "status='trusted'":                ("status=?",          ("trusted",)),
}


async def db_count(table: str, where: str = "") -> int:
    if table not in _ALLOWED_TABLES:
        log.warning("db_count: disallowed table '%s'", table)
        return 0
    try:
        if where:
            preset = _WHERE_PRESETS.get(where)
            if preset:
                clause, params = preset
                q = f"SELECT COUNT(*) FROM {table} WHERE {clause}"
                async with mdb() as db:
                    cur = await db.execute(q, params)
                    row = await cur.fetchone()
            else:
                # Fallback for legacy callers — strip anything dangerous
                safe_where = re.sub(r"[;'\"]", "", where)
                q = f"SELECT COUNT(*) FROM {table} WHERE {safe_where}"
                log.warning("db_count: non-preset where='%s', sanitised", where)
                async with mdb() as db:
                    cur = await db.execute(q)
                    row = await cur.fetchone()
        else:
            async with mdb() as db:
                cur = await db.execute(f"SELECT COUNT(*) FROM {table}")
                row = await cur.fetchone()
        return row[0] if row else 0
    except Exception as exc:
        log.error("db_count(%s, %s): %s", table, where, exc)
        return 0


